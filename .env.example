# Telegram Bot Token — get from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID — get from @userinfobot
TELEGRAM_CHAT_ID=123456789

# Absolute path to your NAS directory on the host
HOST_DATA_DIR=/mnt/nas

# Optional — destructive operations are throttled to one per N seconds
# per user. Lower = more responsive, higher = harder to spam.
RATE_LIMIT_INTERVAL=2.0

# Optional — uploads larger than this many MB are rejected up front.
# Telegram's bot API normally caps downloads around 20 MB unless you
# run a local Bot API server; this ceiling is mostly to stop a giant
# payload from filling /data accidentally.
MAX_FILE_SIZE_MB=500
